# KyberCrypt web service — Caddy v2 reverse proxy with automatic HTTPS.
#
# The bare domain is CANONICAL: it serves the app, and WEB_BASE_URL points at
# it so share links use it. send.<domain> is kept as an alias that serves the
# same app (so older links and API hosts keep working). Replace kybercrypt.com
# with your own domain — Caddy provisions/renews the TLS cert automatically.
#
# Caddy v2 streams bodies with no upload size limit by default; the service
# caps uploads via WEB_MAX_BYTES. Runs alongside the relay on one droplet —
# keep all site blocks together in /etc/caddy/Caddyfile.

kybercrypt.com {
	reverse_proxy 127.0.0.1:8090
}

# Alias — same app, keeps existing links/API hosts working.
send.kybercrypt.com {
	reverse_proxy 127.0.0.1:8090
}
