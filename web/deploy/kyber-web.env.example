# Kyber-Zip web service configuration — copy to /etc/kyber-web/kyber-web.env
# and edit, then: sudo systemctl restart kyber-web

# Listen on localhost; Caddy terminates TLS and proxies in.
WEB_ADDR=127.0.0.1:8090

# Public base URL — the CANONICAL domain Caddy serves; used in share links.
# In production this is the bare domain (kybercrypt.com); send.kybercrypt.com is
# kept as an alias that also serves the app.
WEB_BASE_URL=https://kybercrypt.com

# Where ciphertext + metadata are stored. Point at a Block Storage volume
# (e.g. /mnt/web-data) if you expect lots of concurrent uploads.
WEB_DATA_DIR=/var/lib/kyber-web/data

# Max upload size in bytes (default 100 MiB). Note: per-account plan limits
# (free vs pro) are the real cap on sends; this is a global safety ceiling.
WEB_MAX_BYTES=104857600

# Max concurrent uploads being encrypted at once (default 6). Uploads now stream
# (chunked AEAD) rather than buffering whole files, so memory stays bounded;
# raise this if you have spare RAM and want more parallel large transfers.
WEB_MAX_UPLOADS=6

# Default expiry for uploads (Go duration). Lower = less disk use.
WEB_TTL=24h

# Tamper-evidence key for the audit log (data/audit.log). The log is hash-chained
# with HMAC-SHA256 under this key; with it set, an attacker who can write the log
# file still cannot forge a valid chain. Generate a random value and keep it HERE
# (this env file, outside the data dir) — NOT on the data volume:
#   openssl rand -base64 32
# If unset, the log is still chained (SHA-256) but only detects naive tampering.
AUDIT_HMAC_KEY=
