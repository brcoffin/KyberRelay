# Kyber-Zip web backup config — copy to /etc/kyber-web/backup.env
# (Optional; sensible defaults apply without it.)

# How many local encrypted backups to keep.
BACKUP_KEEP=14

# --- Off-box upload (STRONGLY recommended; local backups don't survive a
# droplet loss). Requires the aws CLI (`apt install awscli`). For DigitalOcean
# Spaces, create a Space + access keys and set: ---
# BACKUP_S3_BUCKET=s3://my-space-name/kyber-web
# BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
