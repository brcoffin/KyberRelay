# Kyber-Zip relay configuration — copy to /etc/kyber-relay/kyber-relay.env
# and edit. The systemd unit loads this file; run
#   sudo systemctl restart kyber-relay
# after changing anything.

# Listen address. Keep this on localhost — Caddy terminates TLS and proxies in.
RELAY_ADDR=127.0.0.1:8080

# Where blobs are stored. Point this at a mounted Block Storage volume
# (e.g. /mnt/relay-data) if you expect lots of concurrent large transfers.
RELAY_DATA_DIR=/var/lib/kyber-relay/data

# How long an undelivered blob lives before it's swept. Lower = less disk use.
RELAY_TTL=24h

# Maximum upload size in bytes (default 2 GiB).
RELAY_MAX_BYTES=2147483648

# To terminate TLS in the relay itself instead of Caddy, set these and change
# RELAY_ADDR to :443 (then you don't need Caddy):
# RELAY_TLS_CERT=/etc/kyber-relay/fullchain.pem
# RELAY_TLS_KEY=/etc/kyber-relay/privkey.pem
