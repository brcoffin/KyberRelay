# Store text files as LF in the repo; let Git handle working-tree endings.
* text=auto

# Binary artifacts Git must never line-ending-normalize.
*.pdf  binary
*.png  binary
*.svg  -text
*.jpg  binary

# Files that run on Linux MUST keep LF in the working tree too, or they break
# (shell shebangs, systemd units, Caddy config).
*.sh          text eol=lf
*.service     text eol=lf
*.timer       text eol=lf
*.env.example text eol=lf
Caddyfile     text eol=lf
*.go          text eol=lf
go.mod        text eol=lf
go.sum        text eol=lf
